{
  "manifest_version": 3,
  "name": "VRM - Vinted Sync",
  "version": "3.4.0",
  "description": "Synchronise, depuis TON navigateur (ton IP), tes comptes et donnees Vinted (annonces, ventes, achats, messages) vers VRM. Fetch actif + capture passive + renouvellement auto du login + actions 1-clic (repondre, offre) executees depuis ton navigateur. Aucun appel via un serveur.",
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://*.vinted.fr/*",
    "https://*.vinted.com/*",
    "https://*.vinted.it/*",
    "https://*.vinted.de/*",
    "https://lgonxzrzjcqthjtbdpzo.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.vinted.fr/*",
        "https://*.vinted.com/*",
        "https://*.vinted.it/*",
        "https://*.vinted.de/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "https://cancale-v67-ten.vercel.app/*",
        "https://cancale-v67.vercel.app/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://*.vinted.fr/*",
        "https://*.vinted.com/*",
        "https://*.vinted.it/*",
        "https://*.vinted.de/*"
      ]
    }
  ],
  "action": { "default_popup": "popup.html", "default_title": "Shop Cancale35 - Vinted Sync" }
}
